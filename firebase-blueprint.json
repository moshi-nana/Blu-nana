{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["email", "createdAt", "updatedAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense", "debt"] },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "classification": { "type": "string", "enum": ["personal", "business"] },
        "ownerId": { "type": "string" },
        "isDebt": { "type": "boolean" },
        "debtType": { "type": "string", "enum": ["borrow", "lend"] },
        "isSettled": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "amount", "type", "category", "date", "time", "classification", "ownerId", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User documents"
    },
    "users/{userId}/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Transactions belonging to a user"
    }
  }
}
